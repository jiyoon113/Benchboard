---
import Page from "../../layouts/Page.astro";
import CategoryTabs from "../../components/CategoryTabs.astro";
import LeaderboardTable from "../../components/LeaderboardTable.tsx";
import CurationNote from "../../components/CurationNote.astro";
import { buildView } from "../../lib/loadData.ts";
import "../../styles/global.css";

const view = await buildView("video");
---

<Page title="Video">
  <CategoryTabs active="video" />
  <CurationNote hidden={view.hiddenBenchmarks} allHref="/deterministic/all" />
  <LeaderboardTable client:load benchmarks={view.benchmarks} rows={view.rows} />
</Page>
