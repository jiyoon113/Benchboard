# Copy this file to .env and fill in your values.
# benchboard never reads or modifies .env itself — only your shell exports
# the values from it. .env is gitignored.

# === Required for tech-report PDF ingestion ===
# OpenAI-compatible endpoint (DashScope, Ollama, OpenRouter, vLLM, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Examples — pick what you have, set the three vars above accordingly:
#
# Qwen via DashScope (Alibaba):
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   OPENAI_MODEL=qwen3-8b
#
# Local Ollama (cost = 0, needs `ollama pull qwen3:8b` first):
#   OPENAI_API_KEY=ollama        # any non-empty string; Ollama ignores it
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=qwen3:8b
#
# OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=qwen/qwen3-8b
